  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Informasi Teknis Lapangan Basket GOR Lama IPB</b>\n\n\u2022 <b>Jenis
    Permukaan:</b> Cor Beton Semen Keras (Hard Court)\n\u2022 <b>Ukuran Lapangan:</b>
    28 x 15 meter (Standar Resmi FIBA)\n\u2022 <b>Fasilitas:</b> Ring basket dengan
    jaring besi, papan pantul akrilik\n\u2022 <b>Garis Batas:</b> Garis batas luar,
    area 3-point (6.75m), garis free throw\n\u2022 <b>Lokasi:</b> Kompleks GOR Lama,
    Jl. Agatis, Kampus IPB Dramaga"

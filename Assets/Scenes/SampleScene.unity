  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Sejarah & Filosofi GOR Lama IPB</b>\n\n\u2022 <b>Sejarah:</b> Merupakan
    salah satu fasilitas olahraga tertua di Kampus Dramaga, saksi bisu perkembangan
    prestasi UKM Olahraga IPB.\n\u2022 <b>Filosofi:</b> Lapangan outdoor melambangkan
    semangat keterbukaan, sportivitas, dan kerja keras pantang menyerah di bawah
    terik matahari.\n\u2022 <b>Peran:</b> Menjadi pusat interaksi sosial mahasiswa
    lintas fakultas melalui kompetisi persahabatan antar angkatan."

  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Fakta Menarik & Penggunaan Lapangan</b>\n\n\u2022 <b>Kegiatan Rutin:</b>
    Menjadi tempat latihan rutin UKM Bola Basket IPB, turnamen lokal mahasiswa, dan
    latihan fisik pagi.\n\u2022 <b>Kedekatan Masjid:</b> Terletak tepat di seberang
    jalan Masjid Al-Hurriyyah IPB, memudahkan mahasiswa beribadah setelah selesai
    bermain.\n\u2022 <b>Keunikan:</b> Di sekeliling lapangan dikelilingi pohon rindang
    kampus, memberikan suasana teduh saat sore hari."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f675742eaf9c20a4f909d78ee7a14fed, type: 2}
